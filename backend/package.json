{
  "name": "healthcare-appointment-backend",
  "version": "1.0.0",
  "description": "Healthcare appointment reminder system - backend API",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "dev:nodemon": "nodemon server.js",
    "seed": "node scripts/seedAdmin.js"
  },
  "nodemonConfig": {
    "exec": "node server.js",
    "watch": ["*.js", "controllers", "models", "routes", "middleware", "services", "cron", "utils"],
    "ext": "js,json",
    "delay": "500"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "mongo-sanitize": "^1.1.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "socket.io": "^4.7.2",
    "validator": "^13.11.0",
    "xss-clean": "^0.1.4"
  }
}
